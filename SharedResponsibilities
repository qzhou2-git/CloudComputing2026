<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shared Responsibility Model Interactive Lesson</title>
  <style>
    :root {
      --primary: #1e3a8a;
      --secondary: #2563eb;
      --accent: #f97316;
      --success: #16a34a;
      --danger: #dc2626;
      --warning: #facc15;
      --bg: #f5f8ff;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #64748b;
      --line: #dbeafe;
      --provider: #e0f2fe;
      --customer: #fff7ed;
      --shared: #fef9c3;
      --shadow: rgba(30, 58, 138, 0.15);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 32%),
        radial-gradient(circle at bottom right, rgba(249, 115, 22, 0.15), transparent 35%),
        var(--bg);
      line-height: 1.55;
    }

    header {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      padding: 2rem 1rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    header::after {
      content: "🔐";
      position: absolute;
      right: 7%;
      top: 18%;
      font-size: 7rem;
      opacity: 0.18;
      animation: floatIcon 4s ease-in-out infinite;
    }

    @keyframes floatIcon {
      0%, 100% { transform: translateY(0) rotate(-4deg); }
      50% { transform: translateY(-12px) rotate(4deg); }
    }

    header h1 {
      margin: 0;
      font-size: clamp(2rem, 5vw, 3.6rem);
    }

    header p {
      max-width: 900px;
      margin: 0.75rem auto 0;
      font-size: 1.1rem;
    }

    main {
      width: min(1140px, 94vw);
      margin: 1.5rem auto 3rem;
    }

    .layout {
      display: grid;
      grid-template-columns: 285px 1fr;
      gap: 1rem;
      align-items: start;
    }

    nav {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 1rem;
      box-shadow: 0 12px 30px var(--shadow);
      position: sticky;
      top: 1rem;
    }

    nav h2 {
      margin: 0 0 0.75rem;
      font-size: 1rem;
      color: var(--primary);
    }

    nav button {
      width: 100%;
      margin: 0.3rem 0;
      border: 1px solid var(--line);
      background: white;
      border-radius: 14px;
      padding: 0.75rem;
      text-align: left;
      font-weight: 700;
      color: var(--text);
      cursor: pointer;
      transition: 0.2s ease;
    }

    nav button:hover,
    nav button.active {
      background: #eff6ff;
      border-color: var(--secondary);
      transform: translateX(3px);
    }

    .progress-card {
      margin-top: 1rem;
      padding: 0.9rem;
      border-radius: 16px;
      background: #eff6ff;
      border: 1px solid var(--line);
    }

    .meter {
      height: 14px;
      background: #dbeafe;
      border-radius: 999px;
      overflow: hidden;
      margin-top: 0.5rem;
    }

    .meter div {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--secondary), var(--accent));
      transition: width 0.35s ease;
    }

    .panel {
      display: none;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid var(--line);
      border-radius: 26px;
      padding: clamp(1rem, 3vw, 1.75rem);
      box-shadow: 0 14px 35px var(--shadow);
      min-height: 660px;
    }

    .panel.active {
      display: block;
      animation: fadeIn 0.25s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .tag {
      display: inline-block;
      background: #dbeafe;
      color: var(--primary);
      border-radius: 999px;
      padding: 0.35rem 0.75rem;
      font-weight: 800;
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
    }

    h2, h3 { color: var(--primary); }

    .hero-box,
    .callout,
    .activity-card,
    .model-card {
      background: white;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 1rem;
      margin: 1rem 0;
      box-shadow: 0 8px 18px rgba(30, 58, 138, 0.07);
    }

    .hero-box {
      background: linear-gradient(135deg, #eff6ff, #ffffff);
      border-left: 8px solid var(--secondary);
    }

    .callout {
      background: #fff7ed;
      border-left: 8px solid var(--accent);
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .model-card {
      min-height: 230px;
      position: relative;
      overflow: hidden;
    }

    .model-card .icon {
      font-size: 2.8rem;
      display: block;
      margin-bottom: 0.5rem;
    }

    .provider-card { border-top: 8px solid #2563eb; }
    .customer-card { border-top: 8px solid #f97316; }
    .shared-card { border-top: 8px solid #facc15; }

    button.primary,
    button.secondary,
    button.small {
      border: 0;
      border-radius: 14px;
      padding: 0.8rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition: 0.2s ease;
    }

    button.primary {
      background: linear-gradient(135deg, var(--secondary), var(--primary));
      color: white;
    }

    button.secondary {
      background: #fff7ed;
      color: #9a3412;
      border: 1px solid #fed7aa;
    }

    button.small {
      padding: 0.5rem 0.7rem;
      background: #eff6ff;
      color: var(--primary);
      border: 1px solid var(--line);
    }

    button.primary:hover,
    button.secondary:hover,
    button.small:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 18px var(--shadow);
    }

    .btn-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-top: 1rem;
    }

    .responsibility-visual {
      display: grid;
      gap: 0.55rem;
      margin: 1rem 0;
    }

    .layer {
      padding: 0.85rem;
      border-radius: 14px;
      border: 1px solid var(--line);
      font-weight: 800;
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
    }

    .provider { background: var(--provider); }
    .customer { background: var(--customer); }
    .shared { background: var(--shared); }

    .service-tabs {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .service-tab {
      background: white;
      border: 2px solid var(--line);
      border-radius: 16px;
      padding: 1rem;
      cursor: pointer;
      font-weight: 800;
      text-align: center;
      transition: 0.2s ease;
    }

    .service-tab:hover,
    .service-tab.selected {
      background: #eff6ff;
      border-color: var(--secondary);
      transform: translateY(-2px);
    }

    .sort-board {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 1rem;
    }

    .cards,
    .dropzones {
      display: grid;
      gap: 0.7rem;
    }

    .drag-card {
      background: white;
      border: 2px solid var(--line);
      border-radius: 14px;
      padding: 0.8rem;
      cursor: grab;
      font-weight: 700;
      box-shadow: 0 6px 14px rgba(30, 58, 138, 0.08);
    }

    .drag-card:focus {
      outline: 3px solid var(--accent);
    }

    .dropzones {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .dropzone {
      min-height: 260px;
      background: #f8fafc;
      border: 2px dashed #93c5fd;
      border-radius: 18px;
      padding: 0.8rem;
    }

    .dropzone h3 {
      margin-top: 0;
      font-size: 1.05rem;
    }

    .dropzone.over {
      background: #eff6ff;
      border-color: var(--secondary);
    }

    .dropped {
      margin: 0.4rem 0;
      padding: 0.6rem;
      border-radius: 12px;
      background: white;
      border: 1px solid var(--line);
    }

    .scenario-grid {
      display: grid;
      gap: 0.85rem;
    }

    .scenario {
      background: white;
      border: 2px solid var(--line);
      border-radius: 18px;
      padding: 1rem;
    }

    select,
    textarea,
    input[type="text"] {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 12px;
      padding: 0.75rem;
      font: inherit;
      background: white;
      margin-top: 0.4rem;
    }

    textarea {
      min-height: 95px;
      resize: vertical;
    }

    label {
      display: block;
      margin-top: 0.8rem;
      font-weight: 800;
    }

    .feedback {
      margin-top: 0.8rem;
      padding: 0.8rem;
      border-radius: 14px;
      background: #f8fafc;
      border: 1px solid var(--line);
      font-weight: 700;
    }

    .feedback.good {
      background: #ecfdf5;
      border-color: #bbf7d0;
      color: #166534;
    }

    .feedback.bad {
      background: #fef2f2;
      border-color: #fecaca;
      color: #991b1b;
    }

    .quiz-option {
      display: block;
      width: 100%;
      text-align: left;
      margin: 0.5rem 0;
      background: white;
      border: 2px solid var(--line);
      border-radius: 14px;
      padding: 0.85rem;
      cursor: pointer;
      font-weight: 700;
    }

    .quiz-option.correct {
      border-color: var(--success);
      background: #ecfdf5;
    }

    .quiz-option.wrong {
      border-color: var(--danger);
      background: #fef2f2;
    }

    .badge {
      display: inline-block;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: #eff6ff;
      border: 1px solid var(--line);
      margin: 0.25rem;
      font-weight: 800;
      color: var(--primary);
    }

    .summary-output {
      white-space: pre-wrap;
      background: #f8fafc;
      border: 1px dashed var(--secondary);
      border-radius: 18px;
      padding: 1rem;
      min-height: 210px;
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
      overflow: hidden;
      border-radius: 16px;
    }

    .compare-table th,
    .compare-table td {
      border: 1px solid var(--line);
      padding: 0.75rem;
      text-align: left;
      vertical-align: top;
    }

    .compare-table th {
      background: #eff6ff;
      color: var(--primary);
    }

    footer {
      text-align: center;
      margin-top: 2rem;
      color: var(--muted);
      font-weight: 700;
    }

    @media (max-width: 950px) {
      .layout,
      .grid-3,
      .sort-board,
      .dropzones,
      .service-tabs {
        grid-template-columns: 1fr;
      }

      nav {
        position: static;
      }

      header::after {
        display: none;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Shared Responsibility Model</h1>
    <p>Interactive freshman lesson: learn who secures what in the cloud through examples, service comparisons, sorting, scenarios, and a quick quiz.</p>
  </header>

  <main>
    <div class="layout">
      <nav aria-label="Lesson navigation">
        <h2>Lesson Menu</h2>
        <button class="active" data-panel="welcome">1. Welcome</button>
        <button data-panel="concept">2. Big Idea</button>
        <button data-panel="providerCustomer">3. Who Does What?</button>
        <button data-panel="serviceExplorer">4. Service Explorer</button>
        <button data-panel="sort">5. Sort Responsibilities</button>
        <button data-panel="scenario">6. Cloud Scenarios</button>
        <button data-panel="quiz">7. Knowledge Check</button>
        <button data-panel="wrap">8. Wrap-Up</button>

        <div class="progress-card">
          <strong>Progress</strong>
          <div class="meter"><div id="progressBar"></div></div>
          <p id="progressText">0% complete</p>
        </div>
      </nav>

      <section>
        <article id="welcome" class="panel active">
          <span class="tag">Community College Cloud Computing</span>
          <h2>Welcome, Future Cloud Security Thinkers!</h2>
          <div class="hero-box">
            <strong>Today’s goal:</strong> By the end of this lesson, you will be able to explain the Shared Responsibility Model and identify whether the cloud provider or the customer is responsible for common security tasks.
          </div>

          <p>
            When we use cloud computing, security is not handled by just one side. The cloud provider protects some parts, and the customer protects other parts. This shared approach is called the <strong>Shared Responsibility Model</strong>.
          </p>

          <div class="grid-3">
            <div class="model-card provider-card">
              <span class="icon">🏢</span>
              <h3>Cloud Provider</h3>
              <p>Protects the physical data centers, hardware, networking equipment, and core cloud infrastructure.</p>
            </div>
            <div class="model-card customer-card">
              <span class="icon">👤</span>
              <h3>Customer</h3>
              <p>Protects accounts, passwords, permissions, data, applications, and configuration choices.</p>
            </div>
            <div class="model-card shared-card">
              <span class="icon">🤝</span>
              <h3>Shared</h3>
              <p>Some responsibilities involve both sides, such as security awareness, patching strategy, and access control planning.</p>
            </div>
          </div>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('concept')">Start Lesson</button>
          </div>
        </article>

        <article id="concept" class="panel">
          <span class="tag">Beginner Big Idea</span>
          <h2>Security “of” the Cloud vs. Security “in” the Cloud</h2>

          <div class="callout">
            <strong>Real-world application:</strong> Imagine a student club creates a website for event sign-ups using AWS. AWS protects the data centers and cloud infrastructure. The student team must still choose strong passwords, control who can edit the website, and avoid accidentally making private data public.
          </div>

          <table class="compare-table">
            <thead>
              <tr>
                <th>Phrase</th>
                <th>Meaning</th>
                <th>Example</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Security of the Cloud</strong></td>
                <td>The cloud provider protects the cloud infrastructure itself.</td>
                <td>Physical buildings, servers, storage hardware, networking hardware.</td>
              </tr>
              <tr>
                <td><strong>Security in the Cloud</strong></td>
                <td>The customer protects what they put into the cloud and how they configure it.</td>
                <td>User accounts, permissions, data, applications, firewall rules, passwords.</td>
              </tr>
            </tbody>
          </table>

          <div class="activity-card">
            <h3>Quick Reflection</h3>
            <label for="reflection">Why do you think customers still have security responsibilities even when they use the cloud?</label>
            <textarea id="reflection" placeholder="Example: Customers decide who gets access, what data is uploaded, and how their applications are configured..."></textarea>
            <div class="btn-row">
              <button class="primary" onclick="saveReflection()">Save Reflection</button>
            </div>
            <p id="reflectionFeedback" class="feedback">Your response will appear in your final summary.</p>
          </div>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('providerCustomer')">Next: Who Does What?</button>
          </div>
        </article>

        <article id="providerCustomer" class="panel">
          <span class="tag">Core Concept</span>
          <h2>Who Does What?</h2>
          <p>
            Think of the cloud as an apartment building. The landlord protects the building structure, locks, elevators, and common areas. You still lock your own door, protect your belongings, and decide who gets a key.
          </p>

          <div class="responsibility-visual">
            <div class="layer provider"><span>Cloud Provider</span><span>Data centers, hardware, networking, global infrastructure</span></div>
            <div class="layer shared"><span>Shared</span><span>Awareness, patching strategy, monitoring, security planning</span></div>
            <div class="layer customer"><span>Customer</span><span>Data, identities, permissions, passwords, applications, settings</span></div>
          </div>

          <div class="grid-3">
            <div class="model-card provider-card">
              <h3>Provider Examples</h3>
              <ul>
                <li>Physical data center security</li>
                <li>Power and cooling</li>
                <li>Server hardware</li>
                <li>Cloud networking infrastructure</li>
              </ul>
            </div>
            <div class="model-card customer-card">
              <h3>Customer Examples</h3>
              <ul>
                <li>Strong passwords and MFA</li>
                <li>User permissions</li>
                <li>Data classification</li>
                <li>Application security</li>
              </ul>
            </div>
            <div class="model-card shared-card">
              <h3>Shared Examples</h3>
              <ul>
                <li>Patch management</li>
                <li>Logging and monitoring</li>
                <li>Security training</li>
                <li>Incident response planning</li>
              </ul>
            </div>
          </div>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('serviceExplorer')">Explore by Cloud Service</button>
          </div>
        </article>

        <article id="serviceExplorer" class="panel">
          <span class="tag">Interactive Explorer</span>
          <h2>Responsibilities Change by Service Type</h2>
          <p>
            The exact responsibility split depends on the cloud service. Customers manage more in IaaS and less in SaaS.
          </p>

          <div class="service-tabs">
            <div class="service-tab selected" onclick="showService('ec2', this)">🖥️ EC2 / IaaS</div>
            <div class="service-tab" onclick="showService('s3', this)">🪣 S3 Storage</div>
            <div class="service-tab" onclick="showService('paas', this)">🛠️ PaaS App</div>
            <div class="service-tab" onclick="showService('saas', this)">📱 SaaS App</div>
          </div>

          <div id="serviceOutput" class="activity-card"></div>

          <div class="callout">
            <strong>Key pattern:</strong> The more managed the service is, the more the provider handles. But the customer is always responsible for using the service safely.
          </div>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('sort')">Try Sorting Responsibilities</button>
          </div>
        </article>

        <article id="sort" class="panel">
          <span class="tag">Hands-On Practice</span>
          <h2>Sort the Responsibilities</h2>
          <p>
            Drag each card into the correct category. If drag-and-drop is difficult, click a card and then click a category box.
          </p>

          <div class="sort-board">
            <div>
              <h3>Responsibility Cards</h3>
              <div id="cards" class="cards"></div>
            </div>

            <div class="dropzones">
              <div class="dropzone" data-type="Provider" tabindex="0">
                <h3>🏢 Provider</h3>
                <p>Security of the cloud</p>
              </div>
              <div class="dropzone" data-type="Customer" tabindex="0">
                <h3>👤 Customer</h3>
                <p>Security in the cloud</p>
              </div>
              <div class="dropzone" data-type="Shared" tabindex="0">
                <h3>🤝 Shared</h3>
                <p>Both sides contribute</p>
              </div>
            </div>
          </div>

          <div class="btn-row">
            <button class="primary" onclick="checkSort()">Check Sorting</button>
            <button class="secondary" onclick="resetSort()">Reset Cards</button>
          </div>
          <p id="sortFeedback" class="feedback">Sort the cards, then check your work.</p>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('scenario')">Apply to Scenarios</button>
          </div>
        </article>

        <article id="scenario" class="panel">
          <span class="tag">Real-World Decision Making</span>
          <h2>Cloud Security Scenarios</h2>
          <p>For each situation, choose who is primarily responsible.</p>

          <div class="scenario-grid">
            <div class="scenario">
              <h3>Scenario 1: Weak Password</h3>
              <p>A student club website admin uses the password “cloud123” and the account is compromised.</p>
              <select id="scenario1">
                <option value="">Choose...</option>
                <option value="Provider">Cloud Provider</option>
                <option value="Customer">Customer</option>
                <option value="Shared">Shared</option>
              </select>
            </div>

            <div class="scenario">
              <h3>Scenario 2: Data Center Door</h3>
              <p>A cloud provider controls who can physically enter the building where cloud servers are located.</p>
              <select id="scenario2">
                <option value="">Choose...</option>
                <option value="Provider">Cloud Provider</option>
                <option value="Customer">Customer</option>
                <option value="Shared">Shared</option>
              </select>
            </div>

            <div class="scenario">
              <h3>Scenario 3: EC2 Operating System Updates</h3>
              <p>A company runs its own virtual server and must update the operating system to fix vulnerabilities.</p>
              <select id="scenario3">
                <option value="">Choose...</option>
                <option value="Provider">Cloud Provider</option>
                <option value="Customer">Customer</option>
                <option value="Shared">Shared</option>
              </select>
            </div>

            <div class="scenario">
              <h3>Scenario 4: Security Monitoring</h3>
              <p>The provider offers logging tools, but the customer must turn on useful logs and review suspicious activity.</p>
              <select id="scenario4">
                <option value="">Choose...</option>
                <option value="Provider">Cloud Provider</option>
                <option value="Customer">Customer</option>
                <option value="Shared">Shared</option>
              </select>
            </div>
          </div>

          <div class="btn-row">
            <button class="primary" onclick="checkScenarios()">Check Scenarios</button>
          </div>
          <p id="scenarioFeedback" class="feedback">Choose a responsibility owner for each scenario.</p>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('quiz')">Take Knowledge Check</button>
          </div>
        </article>

        <article id="quiz" class="panel">
          <span class="tag">Knowledge Check</span>
          <h2>Quick Quiz</h2>
          <div id="quizBox"></div>

          <div class="btn-row">
            <button class="primary" onclick="nextQuiz()">Next Question</button>
            <button class="secondary" onclick="restartQuiz()">Restart Quiz</button>
          </div>

          <p id="quizFeedback" class="feedback">Answer the question to receive feedback.</p>

          <div class="btn-row">
            <button class="primary" onclick="goToPanel('wrap')">Finish Lesson</button>
          </div>
        </article>

        <article id="wrap" class="panel">
          <span class="tag">Wrap-Up</span>
          <h2>Shared Responsibility Model Summary</h2>

          <div class="activity-card">
            <h3>Badges Earned</h3>
            <div id="badgeBox">
              <span class="badge">Cloud Security Beginner</span>
            </div>
          </div>

          <div class="activity-card">
            <h3>Your Personal Study Notes</h3>
            <div id="summaryOutput" class="summary-output">Click the button below to generate your study summary.</div>
            <div class="btn-row">
              <button class="primary" onclick="generateSummary()">Generate Summary</button>
              <button class="secondary" onclick="window.print()">Print or Save as PDF</button>
            </div>
          </div>

          <div class="callout">
            <strong>Exit Ticket:</strong> In one sentence, explain the Shared Responsibility Model to someone new to cloud computing.
            <label for="exitTicket">Your answer:</label>
            <textarea id="exitTicket" placeholder="The Shared Responsibility Model means..."></textarea>
          </div>
        </article>
      </section>
    </div>

    <footer>
      Interactive lesson for incoming cloud computing students · HTML5, CSS, and JavaScript
    </footer>
  </main>

  <script>
    const completed = new Set();
    let selectedCard = null;
    let quizIndex = 0;
    let quizScore = 0;
    let reflection = "";
    let sortScore = 0;
    let scenarioScore = 0;

    const panels = document.querySelectorAll(".panel");
    const navButtons = document.querySelectorAll("nav button");

    const responsibilityCards = [
      { name: "Physical data center security", type: "Provider" },
      { name: "Server hardware maintenance", type: "Provider" },
      { name: "Power, cooling, and building security", type: "Provider" },
      { name: "Strong passwords and MFA", type: "Customer" },
      { name: "User permissions and access control", type: "Customer" },
      { name: "Protecting uploaded data", type: "Customer" },
      { name: "Application code security", type: "Customer" },
      { name: "Logging and monitoring strategy", type: "Shared" },
      { name: "Patch management planning", type: "Shared" },
      { name: "Security awareness and training", type: "Shared" }
    ];

    const quizQuestions = [
      {
        question: "What does the cloud provider usually secure?",
        options: ["The physical data center and core infrastructure", "Every customer password", "Every customer file name"],
        answer: "The physical data center and core infrastructure",
        explain: "The provider is responsible for security of the cloud, including data centers and infrastructure."
      },
      {
        question: "What is the customer usually responsible for?",
        options: ["Power and cooling in the cloud data center", "User permissions, data, and account security", "Replacing cloud provider hardware"],
        answer: "User permissions, data, and account security",
        explain: "Customers control their accounts, permissions, data, applications, and configuration choices."
      },
      {
        question: "In an IaaS service like a virtual machine, who usually patches the operating system?",
        options: ["Customer", "Cloud Provider", "Nobody"],
        answer: "Customer",
        explain: "With IaaS, customers usually manage the operating system, applications, and data."
      },
      {
        question: "Which statement best describes the Shared Responsibility Model?",
        options: ["The provider handles all security", "The customer handles all security", "Security is split between the provider and customer"],
        answer: "Security is split between the provider and customer",
        explain: "Cloud security is shared. The exact split depends on the service being used."
      },
      {
        question: "If a customer accidentally makes a storage bucket public, who is usually responsible for that configuration mistake?",
        options: ["Customer", "Cloud Provider", "Internet Service Provider"],
        answer: "Customer",
        explain: "Customers are responsible for how they configure their cloud resources and permissions."
      }
    ];

    navButtons.forEach(button => {
      button.addEventListener("click", () => goToPanel(button.dataset.panel));
    });

    function goToPanel(id) {
      panels.forEach(panel => panel.classList.remove("active"));
      navButtons.forEach(button => button.classList.remove("active"));

      document.getElementById(id).classList.add("active");
      document.querySelector(`nav button[data-panel="${id}"]`).classList.add("active");

      completed.add(id);
      updateProgress();

      if (id === "sort" && !document.getElementById("cards").children.length) {
        buildSortCards();
      }

      if (id === "quiz") {
        renderQuiz();
      }

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function updateProgress() {
      const total = navButtons.length;
      const percent = Math.round((completed.size / total) * 100);
      document.getElementById("progressBar").style.width = percent + "%";
      document.getElementById("progressText").textContent = percent + "% complete";
    }

    function saveReflection() {
      reflection = document.getElementById("reflection").value.trim();
      const feedback = document.getElementById("reflectionFeedback");

      if (reflection.length > 10) {
        feedback.textContent = "Reflection saved. Great connection to cloud security responsibility.";
        feedback.className = "feedback good";
      } else {
        feedback.textContent = "Try adding one more detail about why customers still have security responsibilities.";
        feedback.className = "feedback bad";
      }
    }

    function showService(type, element) {
      document.querySelectorAll(".service-tab").forEach(tab => tab.classList.remove("selected"));
      element.classList.add("selected");

      const serviceOutput = document.getElementById("serviceOutput");
      const data = {
        ec2: {
          title: "EC2 / IaaS: Customer Manages More",
          rows: [
            ["Provider", "Physical facilities, hardware, networking, virtualization infrastructure"],
            ["Customer", "Operating system patches, applications, data, firewall rules, user accounts"],
            ["Key idea", "You get more control, but you also have more responsibility."]
          ]
        },
        s3: {
          title: "S3 Storage: Provider Manages Storage Infrastructure",
          rows: [
            ["Provider", "Storage hardware, durability infrastructure, physical security"],
            ["Customer", "Bucket permissions, data classification, encryption choices, access policies"],
            ["Key idea", "The provider protects the storage service, but you control how your data is accessed."]
          ]
        },
        paas: {
          title: "PaaS App: Customer Focuses on Code and Data",
          rows: [
            ["Provider", "Servers, operating system, runtime, scaling platform"],
            ["Customer", "Application code, data, users, authentication settings"],
            ["Key idea", "You manage less infrastructure, but still must write safe code and protect data."]
          ]
        },
        saas: {
          title: "SaaS App: Provider Manages the Full Application",
          rows: [
            ["Provider", "Application, servers, updates, platform, infrastructure"],
            ["Customer", "Account security, sharing settings, data usage, user behavior"],
            ["Key idea", "You do not manage the app itself, but you still use it responsibly."]
          ]
        }
      };

      const selected = data[type];
      serviceOutput.innerHTML = `
        <h3>${selected.title}</h3>
        <div class="responsibility-visual">
          ${selected.rows.map(row => {
            let cls = row[0] === "Provider" ? "provider" : row[0] === "Customer" ? "customer" : "shared";
            return `<div class="layer ${cls}"><span>${row[0]}</span><span>${row[1]}</span></div>`;
          }).join("")}
        </div>
      `;
    }

    function buildSortCards() {
      const cards = document.getElementById("cards");
      cards.innerHTML = "";

      shuffle(responsibilityCards).forEach((card, index) => {
        const div = document.createElement("div");
        div.className = "drag-card";
        div.draggable = true;
        div.tabIndex = 0;
        div.id = "card-" + index;
        div.dataset.type = card.type;
        div.textContent = card.name;

        div.addEventListener("dragstart", e => {
          e.dataTransfer.setData("text/plain", div.id);
        });

        div.addEventListener("click", () => {
          document.querySelectorAll(".drag-card").forEach(c => c.style.outline = "none");
          selectedCard = div;
          div.style.outline = "3px solid var(--accent)";
        });

        cards.appendChild(div);
      });

      setupDropzones();
    }

    function setupDropzones() {
      document.querySelectorAll(".dropzone").forEach(zone => {
        zone.addEventListener("dragover", e => {
          e.preventDefault();
          zone.classList.add("over");
        });

        zone.addEventListener("dragleave", () => zone.classList.remove("over"));

        zone.addEventListener("drop", e => {
          e.preventDefault();
          zone.classList.remove("over");
          const id = e.dataTransfer.getData("text/plain");
          const card = document.getElementById(id);
          placeCard(card, zone);
        });

        zone.addEventListener("click", () => {
          if (selectedCard) {
            placeCard(selectedCard, zone);
            selectedCard.style.outline = "none";
            selectedCard = null;
          }
        });
      });
    }

    function placeCard(card, zone) {
      if (!card) return;
      const item = document.createElement("div");
      item.className = "dropped";
      item.dataset.type = card.dataset.type;
      item.textContent = card.textContent;
      zone.appendChild(item);
      card.remove();
    }

    function checkSort() {
      let correct = 0;
      let total = 0;

      document.querySelectorAll(".dropzone").forEach(zone => {
        const zoneType = zone.dataset.type;
        zone.querySelectorAll(".dropped").forEach(item => {
          total++;
          if (item.dataset.type === zoneType) correct++;
        });
      });

      sortScore = correct;
      const feedback = document.getElementById("sortFeedback");

      if (total < responsibilityCards.length) {
        feedback.textContent = `You sorted ${total}/${responsibilityCards.length} cards. Sort all cards before checking.`;
        feedback.className = "feedback bad";
      } else if (correct === responsibilityCards.length) {
        feedback.textContent = "Excellent! All responsibilities are sorted correctly.";
        feedback.className = "feedback good";
      } else {
        feedback.textContent = `You got ${correct}/${responsibilityCards.length}. Review who manages each responsibility and try again.`;
        feedback.className = "feedback bad";
      }
    }

    function resetSort() {
      document.querySelectorAll(".dropzone .dropped").forEach(item => item.remove());
      buildSortCards();
      document.getElementById("sortFeedback").textContent = "Cards reset. Try sorting again.";
      document.getElementById("sortFeedback").className = "feedback";
    }

    function checkScenarios() {
      const answers = {
        scenario1: "Customer",
        scenario2: "Provider",
        scenario3: "Customer",
        scenario4: "Shared"
      };

      scenarioScore = 0;
      Object.keys(answers).forEach(id => {
        if (document.getElementById(id).value === answers[id]) scenarioScore++;
      });

      const feedback = document.getElementById("scenarioFeedback");
      if (scenarioScore === 4) {
        feedback.textContent = "Perfect! You correctly applied the Shared Responsibility Model.";
        feedback.className = "feedback good";
      } else {
        feedback.textContent = `You got ${scenarioScore}/4. Hint: passwords and EC2 OS updates are customer responsibilities; data center physical security is provider responsibility; monitoring often involves both.`;
        feedback.className = "feedback bad";
      }
    }

    function renderQuiz() {
      const quizBox = document.getElementById("quizBox");
      const q = quizQuestions[quizIndex];

      quizBox.innerHTML = `
        <div class="activity-card">
          <h3>Question ${quizIndex + 1} of ${quizQuestions.length}</h3>
          <p><strong>${q.question}</strong></p>
          ${q.options.map(option => `
            <button class="quiz-option" onclick="answerQuiz(this, '${option.replace(/'/g, "\\'")}')">${option}</button>
          `).join("")}
        </div>
      `;

      document.getElementById("quizFeedback").textContent = "Answer the question to receive feedback.";
      document.getElementById("quizFeedback").className = "feedback";
    }

    function answerQuiz(button, answer) {
      const q = quizQuestions[quizIndex];
      const options = document.querySelectorAll(".quiz-option");

      options.forEach(btn => {
        btn.disabled = true;
        if (btn.textContent === q.answer) btn.classList.add("correct");
      });

      if (answer === q.answer) {
        button.classList.add("correct");
        quizScore++;
        document.getElementById("quizFeedback").textContent = "Correct! " + q.explain;
        document.getElementById("quizFeedback").className = "feedback good";
      } else {
        button.classList.add("wrong");
        document.getElementById("quizFeedback").textContent = "Not quite. " + q.explain;
        document.getElementById("quizFeedback").className = "feedback bad";
      }
    }

    function nextQuiz() {
      if (quizIndex < quizQuestions.length - 1) {
        quizIndex++;
        renderQuiz();
      } else {
        document.getElementById("quizFeedback").textContent = `Quiz complete! Your current score is ${quizScore}/${quizQuestions.length}.`;
        document.getElementById("quizFeedback").className = quizScore >= 4 ? "feedback good" : "feedback bad";
      }
    }

    function restartQuiz() {
      quizIndex = 0;
      quizScore = 0;
      renderQuiz();
    }

    function generateSummary() {
      const exitTicket = document.getElementById("exitTicket").value.trim();
      const summary = `My Shared Responsibility Model Study Notes

Main Idea:
The Shared Responsibility Model means cloud security is divided between the cloud provider and the customer.

Security of the Cloud:
The cloud provider protects the cloud infrastructure, including physical data centers, hardware, networking, power, cooling, and core cloud services.

Security in the Cloud:
The customer protects what they put in the cloud and how they configure it, including data, identities, access permissions, passwords, applications, and security settings.

Important Pattern:
The exact responsibility split depends on the service. In IaaS, customers manage more. In SaaS, customers manage less, but they still must use the service responsibly.

My Reflection:
${reflection || "No reflection saved yet."}

Practice Scores:
Sorting Activity: ${sortScore}/10
Scenario Activity: ${scenarioScore}/4
Quiz Score: ${quizScore}/5

My Exit Ticket:
${exitTicket || "Write your one-sentence explanation here."}`;

      document.getElementById("summaryOutput").textContent = summary;
      updateBadges();
    }

    function updateBadges() {
      const badges = ["Cloud Security Beginner"];
      if (reflection.length > 10) badges.push("Reflective Learner");
      if (sortScore >= 8) badges.push("Responsibility Sorter");
      if (scenarioScore === 4) badges.push("Scenario Solver");
      if (quizScore >= 4) badges.push("Cloud Security Champ");

      document.getElementById("badgeBox").innerHTML = badges
        .map(badge => `<span class="badge">${badge}</span>`)
        .join("");
    }

    function shuffle(array) {
      return [...array].sort(() => Math.random() - 0.5);
    }

    showService("ec2", document.querySelector(".service-tab"));
    updateProgress();
  </script>
</body>
</html>
